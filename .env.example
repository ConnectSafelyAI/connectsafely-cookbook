# Get your key at https://connectsafely.ai/api-key?utm_source=github&utm_medium=cookbook&utm_campaign=env
CONNECTSAFELY_API_KEY=

# Optional: target a specific LinkedIn account if you have multiple connected.
# Leave blank to use the default account on your key.
CONNECTSAFELY_ACCOUNT_ID=

# Optional: enables --ai claude on prospect-researcher and any future skill
# that supports LLM drafting. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: enables --ai openai. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
